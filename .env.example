PORT=5000

# MongoDB Atlas URI (must have Vector Search index enabled)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/opsmind?retryWrites=true&w=majority

# Anthropic API Key (used for embeddings via voyage + answers via claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Admin secret for protected upload/delete routes
ADMIN_SECRET=your_admin_secret_here
